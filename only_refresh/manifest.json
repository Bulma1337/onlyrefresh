{
  "manifest_version": 3,
  "name": "Only Refresh",
  "version": "1.0.0",
  "description": "Auto-reload the current tab at configurable intervals, with an on-page countdown ring and optional auto-scroll. Local-only, no tracking.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Only Refresh",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "alarms"
  ],
  "optional_host_permissions": [
    "*://*/*"
  ]
}
